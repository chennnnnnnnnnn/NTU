# Copy to .env.local and fill in your own Supabase project's values.
# Get these from Supabase Dashboard → Project Settings → API.

# Project URL — root only, do NOT include a trailing /rest/v1
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# anon public key (safe for the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# service_role secret key — SERVER ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...
